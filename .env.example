# Copy this file to .env and fill in real values. Never commit .env itself.

# The single shared passphrase all 10 users will type to log in.
APP_PASSPHRASE=change-me-to-something-strong

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port the server listens on (most hosts set this automatically).
PORT=3000
