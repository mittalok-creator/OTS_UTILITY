# Copy this file to .env and fill in real values. Never commit .env itself.

# Admin passphrase — logs in with upload access (Update Data button visible + enabled).
ADMIN_PASSPHRASE=change-me-to-something-strong

# Regular-user passphrase — search/detail/calculate only, no data upload.
USER_PASSPHRASE=change-me-too

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port the server listens on (most hosts set this automatically).
PORT=3000
